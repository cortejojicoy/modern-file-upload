{
    "name": "kukux/modern-file-upload",
    "description": "This is Modern File Upload",
    "keywords": [
        "laravel",
        "filamentphp",
        "filament-plugin",
        "modern-file-upload"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "cortejojicoy",
            "email": "jicoy.cortejo@gmail.com",
            "role": "Software Engineer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0|^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.7|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Kukux\\ModernFileUpload\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kukux\\ModernFileUpload\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kukux\\ModernFileUpload\\ModernFileUploadServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
